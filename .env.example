# AffectSync — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit the .env file to version control.

# Currently no API keys required for MVP (all models run locally).
# This file exists for future integrations (e.g., W&B, cloud storage).

# WANDB_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
